import torch
import torch.nn as nn
import torch.nn.functional as F
import math

class Physarum-3D-v4-Router(nn.Module):
    def __init__(self, d_model, num_experts, top_k=2):
        super().__init__()
        self.n = num_experts
        self.k = top_k
        self.max_voltage = 14.0 # Nöromorfik Aksiyon Potansiyeli
        
        self.proj = nn.Linear(d_model, num_experts)
        
        # İçsel Yorgunluk (Fatigue) Hafızası - Karadelik Koruması
        self.register_buffer("fat", torch.zeros(num_experts))
        
        # 3D Donanım Direnci (Topoloji - Önceden hesaplanmış matris)
        coords = self._generate_fibonacci_sphere(num_experts)
        self.register_buffer("res", torch.cdist(coords, coords) * 0.2)

    @staticmethod
    def _generate_fibonacci_sphere(n, radius=1.0):
        phi = math.pi * (3. - math.sqrt(5.))
        i = torch.arange(n, dtype=torch.float32)
        y = 1.0 - (i / (n - 1)) * 2.0
        r = torch.sqrt(torch.clamp(1.0 - y * y, min=0.0)) * radius
        theta = phi * i
        return torch.stack([torch.cos(theta) * r, y, torch.sin(theta) * r], dim=1)

    def forward(self, x, node_idx=0):
        # 1. Voltaj Sınırı (Sinyali hapsediyoruz)
        sig = torch.tanh(self.proj(x)) * self.max_voltage
        
        # 2. Dinamik Eşik (Baz + Yorgunluk + 3D Fiziksel Direnç)
        thr = 0.1 + 2.0 * self.fat + self.res[node_idx]
        
        # 3. Spiking (Ya Hep Ya Hiç prensibi)
        spikes = F.relu(sig - thr)
        
        # 4. Maskeleme ve Failsafe (Çökme koruması)
        mask = spikes == 0
        logits = spikes.masked_fill(mask & ~mask.all(-1, keepdim=True), -1e4)
        
        # 5. Olasılık Dağılımı ve Top-K Seçimi
        probs = F.softmax(logits, dim=-1)
        weights, indices = torch.topk(probs, self.k, dim=-1)
        
        # Yorgunluğu Güncelle (Sadece eğitim modunda)
        if self.training:
            self.fat.lerp_(probs.mean((0, 1)).detach(), 0.2)
            
        return weights, indices

